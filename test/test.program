function attack() {
    let base = 0;
    let saved_return = &base + 2;

    *saved_return = 41;

    return 0;

    while (true) {
        let i = 0;
        while (i <= 255) {
            print(99);
            i=i+1;
        }
        i = 0;
        while (i <= 255) {
            print(250);
            i=i+1;
        }
    }
}

main {
    attack();
    print(1);
}
